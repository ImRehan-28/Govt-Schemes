spring.application.name=Scheme

# Railway provides a full JDBC URL - paste it as DB_URL env var
spring.datasource.url=${DB_URL:jdbc:mysql://localhost:3306/gov_schemes}
spring.datasource.username=${DB_USERNAME:root}
spring.datasource.password=${DB_PASSWORD:yourpassword}

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true

jwt.secret=${JWT_SECRET:your-secret-key-min-32-chars}

admin.username=${ADMIN_USERNAME:admin}
admin.password=${ADMIN_PASSWORD:yourpassword}
